# ───────────────────────────────────────────
# Industrial Data Bridge - Environment Config
# ───────────────────────────────────────────

# ── Server ──────────────────────────────────
APP_NAME=IndustrialDataBridge
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# ── Database ────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=industrial_bridge
POSTGRES_USER=bridge_user
POSTGRES_PASSWORD=changeme

INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=changeme
INFLUXDB_ORG=industrial-bridge
INFLUXDB_BUCKET=device_telemetry

REDIS_URL=redis://localhost:6379/0

# ── Security ────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
ENCRYPTION_KEY=change-this-32-byte-key-xxxxxx

# ── Device Gateway ──────────────────────────
MODBUS_DEFAULT_PORT=5020
OPCUA_ENDPOINT=opc.tcp://localhost:4840
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=industrial-bridge-gateway

# ── AI Model Config ─────────────────────────
AI_MODEL_PATH=./models
AI_ANOMALY_SENSITIVITY=0.95
AI_PREDICTION_WINDOW=24h
AI_RETRAIN_INTERVAL=7d

# ── Edge Computing ──────────────────────────
EDGE_ENABLED=false
EDGE_DATA_PATH=/data/edge
EDGE_SYNC_INTERVAL=60s

# ── Logging ─────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/bridge.log
LOG_ROTATION=10MB
LOG_RETENTION=30 days

# ── Prometheus / OTEL ───────────────────────
PROMETHEUS_PORT=9090
OTEL_EXPORTER_ENDPOINT=http://localhost:4317